foreground                  = #ffffff
font-family                 = MonoLisaCode
font-size                   = 12
bold-is-bright              = true
font-feature                = calt on, cv01 on, cv02 on, cv03 on, cv04 on, cv05on, cv06 off, cv07 on, cv08 on, cv09 on, cv10 on, cv11 on, cv12 on, dlig on, liga off, ss01 off, ss02 off, ss03 off, ss04 off, ss05 off, ss06 off, ss07 off, ss08 on, ss09 off, ss10 off, ss11 off, ss12 off, ss13 on, ss14 off, ss15 off, zero on
theme                       = catppuccin-mocha.conf
window-padding-x            = 10
window-padding-y            = 10
adjust-font-baseline        = 1
font-synthetic-style        = false
mouse-hide-while-typing     = true
background-opacity          = 1
background-blur             = true
copy-on-select              = false
auto-update-channel         = stable
shell-integration-features  = no-cursor
cursor-style                = block
cursor-style-blink          = true
unfocused-split-opacity     = 1
unfocused-split-fill        = #000000
focus-follows-mouse         = true
